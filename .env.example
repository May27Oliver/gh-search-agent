# Copy to .env and fill in real values.

# --- Provider credentials -------------------------------------------------

# OpenAI API key for gpt-4.1-mini (Phase 1 default model).
OPENAI_API_KEY=

# Anthropic API key for claude-sonnet-4 (Phase 2 cross-provider baseline).
ANTHROPIC_API_KEY=

# DeepSeek access for DeepSeek-R1.
# DEEPSEEK_ENDPOINT is optional; leave blank to use the official API default.
# Examples:
#   - official API:      https://api.deepseek.com
#   - OpenAI-compatible gateway: https://example.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_ENDPOINT=

# GitHub personal access token for Search Repositories API.
# Unauthenticated requests are rate-limited to 10 req/min; a token raises it to 30 req/min.
GITHUB_TOKEN=

# --- Optional overrides ---------------------------------------------------

GH_SEARCH_MODEL=gpt-4.1-mini
# GH_SEARCH_PROVIDER overrides the model→provider mapping when you need to
# route a custom model through a known provider (e.g. hosted DeepSeek gateway).
# Leave blank to use the default mapping from llm/factory.py.
GH_SEARCH_PROVIDER=
GH_SEARCH_MAX_TURNS=5
GH_SEARCH_LOG_ROOT=artifacts/logs
